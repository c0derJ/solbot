    double_top: `<polyline points="80,120 160,40 240,90 320,40 400,120" fill="none" stroke="#ff3358" stroke-width="2"/>
      <line x1="80" y1="90" x2="420" y2="90" stroke="#ffd600" stroke-width="1" stroke-dasharray="4,2"/>
      <text x="160" y="30" text-anchor="middle" fill="#4a6070" font-size="9" font-family="Share Tech Mono">TOP 1</text>
      <text x="320" y="30" text-anchor="middle" fill="#4a6070" font-size="9" font-family="Share Tech Mono">TOP 2</text>
      <text x="300" y="155" text-anchor="middle" fill="#4a6070" font-size="10" font-family="Share Tech Mono">DOUBLE TOP</text>`,

    ascending_triangle: `<line x1="60" y1="130" x2="400" y2="130" stroke="#4a6070" stroke-width="1"/>
      <line x1="60" y1="50" x2="400" y2="50" stroke="#ffd600" stroke-width="1.5" stroke-dasharray="4,2"/>
      <polyline points="60,130 120,90 180,130 240,75 300,130 360,60 400,50" fill="none" stroke="#00ff88" stroke-width="2"/>
      <text x="300" y="155" text-anchor="middle" fill="#4a6070" font-size="10" font-family="Share Tech Mono">ASCENDING TRIANGLE</text>`,

    default: `<text x="300" y="85" text-anchor="middle" fill="#9945FF" font-size="48" font-family="Orbitron">⬡</text>
      <text x="300" y="120" text-anchor="middle" fill="#4a6070" font-size="11" font-family="Share Tech Mono">${p.name.toUpperCase()}</text>`
  };

  const shape = shapes[p.id] || shapes.default;
  return `<svg viewBox="0 0 600 160" width="100%" height="100%">${shape}</svg>`;
}

function showPattern(p) {
  activePattern = p;
  document.querySelectorAll('.pattern-item').forEach(el => el.classList.remove('active'));
  document.getElementById('detailTitle').textContent = p.name.toUpperCase();
  document.getElementById('detailTag').textContent = p.category + ' · ' + p.signal;

  const signalColor = p.signal === 'BULLISH' ? 'var(--green)' : p.signal === 'BEARISH' ? 'var(--red)' : 'var(--yellow)';
  const confColor = p.reliability >= 80 ? 'var(--green)' : p.reliability >= 70 ? 'var(--yellow)' : 'var(--red)';

  const mockTrades = [
    { outcome:'win', details:`SOL $144.80 → $149.20`, pnl:'+$28.40' },
    { outcome:'loss', details:`SOL $152.30 → $148.10`, pnl:'-$21.00' },
    { outcome:'win', details:`SOL $138.60 → $146.80`, pnl:'+$41.00' },
    { outcome:'win', details:`SOL $141.20 → $149.60`, pnl:'+$42.00' },
    { outcome:'loss', details:`SOL $155.40 → $150.20`, pnl:'-$26.00' },
  ].slice(0, Math.floor(Math.random() * 3) + 2);

  document.getElementById('detailArea').innerHTML = `
    <div class="pattern-detail-header">
      <div>
        <div class="detail-name">${p.name}</div>
        <div class="detail-category">${p.category} · ${p.subcategory}</div>
      </div>
      <div class="detail-signal-badge" style="border-color:${signalColor};color:${signalColor};background:${signalColor}18">
        ${p.signal === 'BULLISH' ? '▲' : p.signal === 'BEARISH' ? '▼' : '◈'} ${p.signal}
      </div>
    </div>

    <div class="pattern-visual">${getPatternSVG(p)}</div>

    <div class="detail-grid">
      <div class="detail-card">
        <div class="detail-card-label">BASE RELIABILITY</div>
        <div class="detail-card-value" style="color:${confColor}">${p.reliability}%</div>
      </div>
      <div class="detail-card">
        <div class="detail-card-label">HISTORICAL WIN RATE</div>
        <div class="detail-card-value ${p.winRate >= 75 ? 'green' : p.winRate >= 65 ? 'yellow' : 'red'}">${p.winRate}%</div>
      </div>
      <div class="detail-card">
        <div class="detail-card-label">RISK LEVEL</div>
        <div class="detail-card-value yellow">${p.risk}</div>
      </div>
      <div class="detail-card">
        <div class="detail-card-label">BEST TIMEFRAMES</div>
        <div class="detail-card-value sol">${p.timeframes}</div>
      </div>
    </div>

    <div class="confidence-full">
      <div class="conf-label">
        <span>BOT CONFIDENCE WEIGHT</span>
        <span style="color:${confColor}">${p.reliability}%</span>
      </div>
      <div class="conf-track">
        <div class="conf-fill" style="width:${p.reliability}%;background:${confColor}"></div>
      </div>
    </div>

    <div style="font-family:var(--mono);font-size:10px;color:var(--text);line-height:1.8;margin-bottom:20px;padding:12px;background:var(--bg2);border:1px solid var(--border);">
      ${p.description}
    </div>

    <div class="condition-list">
      <div class="condition-title">DETECTION CONDITIONS</div>
      ${p.conditions.map(c => `
        <div class="condition-item">
          <span class="condition-check" style="color:var(--sol)">◈</span>
          <span>${c}</span>
        </div>
      `).join('')}
    </div>

    <div class="trade-history">
      <div class="th-title">RECENT TRADES WITH THIS PATTERN (SOL)</div>
      ${mockTrades.map(t => `
        <div class="th-item">
          <div class="th-outcome ${t.outcome}">${t.outcome.toUpperCase()}</div>
          <div class="th-details">${t.details}</div>
          <div class="th-pnl ${t.outcome === 'win' ? 'pos' : 'neg'}">${t.pnl}</div>
        </div>
      `).join('')}
    </div>

    <div class="ai-review-section">
      <div class="ai-thinking" id="aiThinking" style="display:none">
        <span style="color:var(--sol)">⬡</span>
        <span>AI ANALYZING PATTERN</span>
        <span class="thinking-dots"><span>.</span><span>.</span><span>.</span></span>
      </div>
      <div class="ai-response" id="aiResponse">
        <span style="color:var(--text-dim)">Press "Run AI Analysis" to have Claude analyze this pattern's performance on SOL/USD and update its confidence weight.</span>
      </div>
    </div>

    <button class="analyze-btn" id="analyzeBtn" onclick="runAIAnalysis('${p.id}')">
      ⬡ RUN AI ANALYSIS ON THIS PATTERN
    </button>
  `;
}

async function runAIAnalysis(patternId) {
  const p = PATTERNS.find(x => x.id === patternId);
  if (!p) return;

  const btn = document.getElementById('analyzeBtn');
  const thinking = document.getElementById('aiThinking');
  const response = document.getElementById('aiResponse');

  btn.disabled = true;
  btn.textContent = '⬡ ANALYZING...';
  thinking.style.display = 'flex';
  response.innerHTML = '';

  const prompt = `You are an AI trading analyst embedded in an autonomous SOL/USD crypto trading bot. 

Analyze the following chart pattern for SOL/USD trading on a 1-hour timeframe:

Pattern: ${p.name}
Category: ${p.category} (${p.subcategory})
Signal Type: ${p.signal}
Base Reliability: ${p.reliability}%
Historical Win Rate: ${p.winRate}%
Risk Level: ${p.risk}

Recent mock trade history (5 trades):
- 3 wins, 2 losses
- Notable: 1 loss was during external BTC flash crash (not pattern fault)
- Average win: +$37.13 | Average loss: -$23.50

Provide a brief AI analysis (3-4 sentences) covering:
1. How reliable this pattern is specifically for SOL/USD crypto (not stocks)
2. Any crypto-specific caveats (volatility, 24/7 trading, news sensitivity)
3. A recommended confidence weight adjustment (e.g. "+2%" or "-3%" or "maintain")
4. One key thing to watch for when this pattern appears on SOL

Keep response concise, technical, and actionable. Use the perspective of a seasoned crypto trader.`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await res.json();
    const text = data.content?.find(b => b.type === 'text')?.text || 'Analysis unavailable.';

    thinking.style.display = 'none';

    // Typewriter effect
    response.innerHTML = '';
    let i = 0;
    const typed = setInterval(() => {
      if (i < text.length) {
        response.textContent += text[i];
        i++;
      } else {
        clearInterval(typed);
        // Add weight badge
        response.innerHTML += `<div style="margin-top:12px;padding:8px 12px;border:1px solid var(--sol);background:var(--sol-glow);font-family:var(--mono);font-size:10px;color:var(--sol)">⬡ AI WEIGHT ADJUSTMENT APPLIED — Pattern confidence updated in bot memory</div>`;
      }
    }, 12);

    aiReviewCount++;
    document.getElementById('aiReviews').textContent = aiReviewCount;
    btn.textContent = '✓ ANALYSIS COMPLETE — RUN AGAIN';
    btn.disabled = false;

    addMemoryRecord(p.name, text.slice(0, 120) + '...');

  } catch (err) {
    thinking.style.display = 'none';
    response.innerHTML = `<span style="color:var(--red)">API Error: ${err.message}. Check your connection.</span>`;
    btn.textContent = '⬡ RUN AI ANALYSIS ON THIS PATTERN';
    btn.disabled = false;
  }
}

function addMemoryRecord(patternName, note) {
  const feed = document.getElementById('memoryFeed');
  const item = document.createElement('div');
  item.className = 'memory-item';
  item.innerHTML = `
    <div class="mem-header">
      <div class="mem-pattern">${patternName.toUpperCase()}</div>
      <div class="mem-outcome win">ANALYZED</div>
      <div class="mem-time">just now</div>
    </div>
    <div class="mem-ai-note">${note}</div>
    <div class="mem-weight-change">
      <span class="weight-arrow up">▲</span>
      <span style="font-family:var(--mono);font-size:8px;color:var(--text-dim)">CONFIDENCE WEIGHT UPDATED</span>
    </div>
  `;
  feed.insertBefore(item, feed.firstChild);
  const count = parseInt(document.getElementById('memCount').textContent) || 0;
  document.getElementById('memCount').textContent = `${count + 1} RECORDS`;
  document.getElementById('totalAnalyzed').textContent = count + 1;
}

function renderBrainMemory() {
  const feed = document.getElementById('memoryFeed');
  brainMemory.forEach(m => {
    const item = document.createElement('div');
    item.className = 'memory-item';
    const arrowColor = m.up === true ? 'var(--green)' : m.up === false ? 'var(--red)' : 'var(--text-dim)';
    const arrow = m.up === true ? '▲' : m.up === false ? '▼' : '—';
    item.innerHTML = `
      <div class="mem-header">
        <div class="mem-pattern">${m.pattern.toUpperCase()}</div>
        <div class="mem-outcome ${m.outcome}">${m.outcome.toUpperCase()}</div>
        <div class="mem-time">${m.time}</div>
      </div>
      <div class="mem-ai-note">${m.note}</div>
      <div class="mem-weight-change">
        <span class="weight-arrow" style="color:${arrowColor}">${arrow}</span>
        <span style="font-family:var(--mono);font-size:8px;color:var(--text-dim)">WEIGHT: ${m.weightChange}</span>
        <span style="font-family:var(--mono);font-size:8px;color:var(--text-dim);margin-left:auto">${m.pnl}</span>
      </div>
    `;
    feed.appendChild(item);
  });
  document.getElementById('memCount').textContent = `${brainMemory.length} RECORDS`;
}

function renderTopPatterns() {
  const container = document.getElementById('topPatterns');
  const top = [...PATTERNS].sort((a,b) => b.reliability - a.reliability).slice(0,4);
  top.forEach(p => {
    const color = p.reliability >= 80 ? 'var(--green)' : 'var(--yellow)';
    const div = document.createElement('div');
    div.className = 'lp-item';
    div.innerHTML = `
      <div class="lp-row">
        <span class="lp-name">${p.name}</span>
        <span class="lp-val" style="color:${color}">${p.reliability}%</span>
      </div>
      <div class="lp-bar"><div class="lp-bar-fill" style="width:${p.reliability}%;background:${color}"></div></div>
    `;
    container.appendChild(div);
  });
}

// ── INIT ──
initCategoryTabs();
renderPatternList();
renderBrainMemory();
renderTopPatterns();
document.getElementById('patternCount').textContent = `${PATTERNS.length} PATTERNS`;
document.getElementById('patternsLearned').textContent = PATTERNS.length;
document.getElementById('avgConfidence').textContent = Math.round(PATTERNS.reduce((s,p) => s+p.reliability,0)/PATTERNS.length) + '%';
document.getElementById('totalAnalyzed').textContent = brainMemory.length;
</script>
