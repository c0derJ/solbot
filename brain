<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SOLBOT // AI BRAIN</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #040608;
  --bg2: #080c10;
  --bg3: #0c1218;
  --panel: #0a0f15;
  --border: #1a2535;
  --border-bright: #1e3a5f;
  --sol: #9945FF;
  --sol-dim: #5a2899;
  --sol-glow: rgba(153,69,255,0.15);
  --green: #00ff88;
  --green-dim: #00994d;
  --green-glow: rgba(0,255,136,0.1);
  --red: #ff3358;
  --red-dim: #991f35;
  --red-glow: rgba(255,51,88,0.1);
  --yellow: #ffd600;
  --cyan: #00d4ff;
  --orange: #ff7c1a;
  --text: #c8d8e8;
  --text-dim: #4a6070;
  --text-bright: #e8f0f8;
  --mono: 'Share Tech Mono', monospace;
  --display: 'Orbitron', monospace;
  --body: 'Rajdhani', sans-serif;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--body);
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content:'';
  position:fixed; top:0;left:0;right:0;bottom:0;
  background: repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);
  pointer-events:none; z-index:9999;
}

body::after {
  content:'';
  position:fixed; top:0;left:0;right:0;bottom:0;
  background-image: linear-gradient(rgba(153,69,255,0.02) 1px,transparent 1px), linear-gradient(90deg,rgba(153,69,255,0.02) 1px,transparent 1px);
  background-size:40px 40px;
  pointer-events:none; z-index:0;
}

/* ── HEADER ── */
header {
  position:relative; z-index:10;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 24px; height:56px;
  border-bottom:1px solid var(--border);
  background:rgba(4,6,8,0.97);
}

.logo { font-family:var(--display); font-size:16px; font-weight:900; letter-spacing:4px; color:var(--sol); text-shadow:0 0 20px var(--sol); }
.logo span { color:var(--text-dim); font-weight:300; font-size:12px; }

.nav-tabs { display:flex; gap:0; }
.nav-tab {
  font-family:var(--mono); font-size:10px; letter-spacing:2px;
  padding:0 20px; height:56px; display:flex; align-items:center;
  border:none; background:transparent; color:var(--text-dim);
  cursor:pointer; border-bottom:2px solid transparent;
  transition:all 0.2s; text-decoration:none;
}
.nav-tab:hover { color:var(--text); }
.nav-tab.active { color:var(--sol); border-bottom-color:var(--sol); background:var(--sol-glow); }

.brain-badge {
  font-family:var(--mono); font-size:9px; letter-spacing:2px;
  padding:4px 12px; border:1px solid var(--sol); color:var(--sol);
  background:var(--sol-glow); animation:pulse-badge 2s infinite;
}
@keyframes pulse-badge { 0%,100%{box-shadow:0 0 8px rgba(153,69,255,0.2)} 50%{box-shadow:0 0 20px rgba(153,69,255,0.5)} }

/* ── LAYOUT ── */
.app { position:relative; z-index:1; display:grid; grid-template-columns:260px 1fr 320px; height:calc(100vh - 56px); }

.panel { background:var(--panel); border:1px solid var(--border); overflow:hidden; display:flex; flex-direction:column; }

.panel-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 16px; border-bottom:1px solid var(--border);
  background:rgba(0,0,0,0.4); flex-shrink:0;
}
.panel-title { font-family:var(--mono); font-size:10px; letter-spacing:3px; color:var(--text-dim); }
.panel-tag { font-family:var(--mono); font-size:9px; color:var(--sol); }

/* ── LEFT — Pattern Library ── */
.left-panel { border-right:1px solid var(--border); }

.search-bar {
  padding:10px 12px; border-bottom:1px solid var(--border); flex-shrink:0;
}
.search-input {
  width:100%; background:var(--bg2); border:1px solid var(--border);
  color:var(--text); font-family:var(--mono); font-size:10px;
  padding:7px 10px; outline:none; letter-spacing:1px;
  transition:border-color 0.2s;
}
.search-input:focus { border-color:var(--sol-dim); }
.search-input::placeholder { color:var(--text-dim); opacity:0.5; }

.category-tabs {
  display:flex; flex-wrap:wrap; gap:4px; padding:8px 12px;
  border-bottom:1px solid var(--border); flex-shrink:0;
}
.cat-tab {
  font-family:var(--mono); font-size:8px; letter-spacing:1px;
  padding:3px 8px; border:1px solid var(--border);
  background:transparent; color:var(--text-dim); cursor:pointer;
  transition:all 0.2s;
}
.cat-tab.active, .cat-tab:hover { border-color:var(--sol-dim); color:var(--sol); background:var(--sol-glow); }

.pattern-list { flex:1; overflow-y:auto; padding:8px 0; }
.pattern-list::-webkit-scrollbar { width:3px; }
.pattern-list::-webkit-scrollbar-thumb { background:var(--border-bright); }

.pattern-item {
  padding:10px 14px; border-bottom:1px solid rgba(26,37,53,0.5);
  cursor:pointer; transition:background 0.15s; display:flex;
  align-items:center; justify-content:space-between;
  animation:fade-in 0.3s ease;
}
@keyframes fade-in { from{opacity:0;transform:translateX(-5px)} to{opacity:1;transform:translateX(0)} }
.pattern-item:hover, .pattern-item.active { background:rgba(153,69,255,0.07); }
.pattern-item.active { border-left:2px solid var(--sol); }

.pattern-left { display:flex; flex-direction:column; gap:3px; }
.pattern-name { font-family:var(--mono); font-size:10px; color:var(--text-bright); letter-spacing:1px; }
.pattern-type { font-family:var(--mono); font-size:8px; color:var(--text-dim); letter-spacing:1px; }

.pattern-right { display:flex; flex-direction:column; align-items:flex-end; gap:3px; }
.confidence-bar-mini { width:40px; height:3px; background:var(--bg3); border:1px solid var(--border); }
.confidence-fill-mini { height:100%; transition:width 0.5s; }
.confidence-pct { font-family:var(--mono); font-size:8px; }

.signal-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }

/* ── CENTER — Pattern Detail + AI Review ── */
.center-panel { border-left:1px solid var(--border); border-right:1px solid var(--border); }

.detail-area { flex:1; overflow-y:auto; padding:20px; }
.detail-area::-webkit-scrollbar { width:3px; }
.detail-area::-webkit-scrollbar-thumb { background:var(--border-bright); }

.pattern-detail-header {
  display:flex; align-items:flex-start; justify-content:space-between;
  margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid var(--border);
}

.detail-name { font-family:var(--display); font-size:20px; font-weight:700; color:var(--text-bright); letter-spacing:2px; margin-bottom:6px; }
.detail-category { font-family:var(--mono); font-size:9px; color:var(--text-dim); letter-spacing:2px; }
.detail-signal-badge {
  font-family:var(--mono); font-size:11px; letter-spacing:2px;
  padding:6px 16px; border:1px solid; font-weight:700;
}

/* Pattern SVG sketch */
.pattern-visual {
  background:var(--bg2); border:1px solid var(--border);
  margin-bottom:20px; position:relative; overflow:hidden;
  height:180px;
}
.pattern-svg { width:100%; height:100%; }

.detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }

.detail-card {
  background:var(--bg2); border:1px solid var(--border); padding:12px;
}
.detail-card-label { font-family:var(--mono); font-size:8px; color:var(--text-dim); letter-spacing:2px; margin-bottom:8px; }
.detail-card-value { font-family:var(--mono); font-size:13px; color:var(--text-bright); }
.detail-card-value.green { color:var(--green); }
.detail-card-value.red { color:var(--red); }
.detail-card-value.yellow { color:var(--yellow); }
.detail-card-value.sol { color:var(--sol); }

.confidence-full { margin-bottom:20px; }
.conf-label { font-family:var(--mono); font-size:9px; color:var(--text-dim); letter-spacing:2px; margin-bottom:8px; display:flex; justify-content:space-between; }
.conf-track { height:6px; background:var(--bg3); border:1px solid var(--border); }
.conf-fill { height:100%; transition:width 1s ease, background 0.5s; }

.condition-list { margin-bottom:20px; }
.condition-title { font-family:var(--mono); font-size:9px; color:var(--text-dim); letter-spacing:2px; margin-bottom:10px; }
.condition-item {
  display:flex; align-items:flex-start; gap:10px;
  padding:7px 0; border-bottom:1px solid rgba(26,37,53,0.4);
  font-size:12px; color:var(--text);
}
.condition-item:last-child { border-bottom:none; }
.condition-check { font-family:var(--mono); font-size:10px; flex-shrink:0; margin-top:1px; }

/* AI Review section */
.ai-review-section { background:var(--bg2); border:1px solid var(--border-bright); padding:16px; margin-bottom:20px; position:relative; }
.ai-review-section::before {
  content:'AI ANALYSIS';
  position:absolute; top:-7px; left:12px;
  font-family:var(--mono); font-size:8px; letter-spacing:2px;
  color:var(--sol); background:var(--bg2); padding:0 6px;
}

.ai-thinking {
  display:flex; align-items:center; gap:8px;
  font-family:var(--mono); font-size:10px; color:var(--sol);
  margin-bottom:12px;
}
.thinking-dots span {
  animation:dot-blink 1.4s infinite;
  display:inline-block;
}
.thinking-dots span:nth-child(2) { animation-delay:0.2s; }
.thinking-dots span:nth-child(3) { animation-delay:0.4s; }
@keyframes dot-blink { 0%,80%,100%{opacity:0} 40%{opacity:1} }

.ai-response {
  font-family:var(--mono); font-size:10px; line-height:1.9;
  color:var(--text); letter-spacing:0.5px;
}
.ai-response .highlight { color:var(--sol); }
.ai-response .pos { color:var(--green); }
.ai-response .neg { color:var(--red); }
.ai-response .warn { color:var(--yellow); }

.analyze-btn {
  font-family:var(--mono); font-size:10px; letter-spacing:2px;
  padding:10px 20px; border:1px solid var(--sol); color:var(--sol);
  background:var(--sol-glow); cursor:pointer; width:100%;
  transition:all 0.2s; text-transform:uppercase;
}
.analyze-btn:hover { box-shadow:0 0 20px rgba(153,69,255,0.3); }
.analyze-btn:disabled { opacity:0.4; cursor:not-allowed; }

/* Trade history mini */
.trade-history { margin-bottom:20px; }
.th-title { font-family:var(--mono); font-size:9px; color:var(--text-dim); letter-spacing:2px; margin-bottom:10px; }
.th-item {
  display:flex; align-items:center; gap:10px;
  padding:6px 0; border-bottom:1px solid rgba(26,37,53,0.4);
  font-family:var(--mono); font-size:9px;
}
.th-outcome { width:40px; text-align:center; padding:2px 6px; border:1px solid; font-size:8px; }
.th-outcome.win { border-color:var(--green); color:var(--green); }
.th-outcome.loss { border-color:var(--red); color:var(--red); }
.th-details { flex:1; color:var(--text-dim); }
.th-pnl { margin-left:auto; }
.th-pnl.pos { color:var(--green); }
.th-pnl.neg { color:var(--red); }

/* ── RIGHT — Brain Memory + Stats ── */
.right-panel { border-left:1px solid var(--border); }

.brain-stats { padding:16px; border-bottom:1px solid var(--border); flex-shrink:0; }

.brain-stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.brain-stat {
  background:var(--bg2); border:1px solid var(--border); padding:10px;
  text-align:center;
}
.bs-value { font-family:var(--display); font-size:16px; font-weight:700; margin-bottom:3px; }
.bs-label { font-family:var(--mono); font-size:8px; color:var(--text-dim); letter-spacing:1px; }

.memory-feed { flex:1; overflow-y:auto; padding:0; }
.memory-feed::-webkit-scrollbar { width:3px; }
.memory-feed::-webkit-scrollbar-thumb { background:var(--border-bright); }

.memory-item {
  padding:12px 14px; border-bottom:1px solid var(--border);
  animation:slide-in 0.4s ease;
}
@keyframes slide-in { from{opacity:0;transform:translateX(10px)} to{opacity:1;transform:translateX(0)} }

.mem-header { display:flex; align-items:center; gap:8px; margin-bottom:6px; }
.mem-pattern { font-family:var(--mono); font-size:10px; color:var(--text-bright); letter-spacing:1px; }
.mem-time { font-family:var(--mono); font-size:8px; color:var(--text-dim); margin-left:auto; }
.mem-outcome { font-family:var(--mono); font-size:8px; padding:1px 6px; border:1px solid; }
.mem-outcome.win { border-color:var(--green); color:var(--green); }
.mem-outcome.loss { border-color:var(--red); color:var(--red); }

.mem-ai-note {
  font-family:var(--mono); font-size:9px; color:var(--text-dim);
  line-height:1.7; border-left:2px solid var(--sol-dim); padding-left:8px;
  margin-top:6px;
}

.mem-weight-change {
  display:flex; align-items:center; gap:6px;
  margin-top:8px; font-family:var(--mono); font-size:8px;
}
.weight-arrow { font-size:10px; }
.weight-arrow.up { color:var(--green); }
.weight-arrow.down { color:var(--red); }

/* Learning progress */
.learning-progress { padding:12px 14px; border-bottom:1px solid var(--border); flex-shrink:0; }
.lp-title { font-family:var(--mono); font-size:8px; color:var(--text-dim); letter-spacing:2px; margin-bottom:10px; }
.lp-item { margin-bottom:8px; }
.lp-row { display:flex; justify-content:space-between; margin-bottom:3px; }
.lp-name { font-family:var(--mono); font-size:9px; color:var(--text); }
.lp-val { font-family:var(--mono); font-size:9px; }
.lp-bar { height:2px; background:var(--bg3); }
.lp-bar-fill { height:100%; transition:width 1s; }
</style>
</head>
