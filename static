<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SOLBOT // Autonomous Trading System</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #040608;
    --bg2: #080c10;
    --bg3: #0c1218;
    --panel: #0a0f15;
    --border: #1a2535;
    --border-bright: #1e3a5f;
    --sol: #9945FF;
    --sol-dim: #5a2899;
    --sol-glow: rgba(153,69,255,0.15);
    --green: #00ff88;
    --green-dim: #00994d;
    --green-glow: rgba(0,255,136,0.1);
    --red: #ff3358;
    --red-dim: #991f35;
    --red-glow: rgba(255,51,88,0.1);
    --yellow: #ffd600;
    --cyan: #00d4ff;
    --text: #c8d8e8;
    --text-dim: #4a6070;
    --text-bright: #e8f0f8;
    --mono: 'Share Tech Mono', monospace;
    --display: 'Orbitron', monospace;
    --body: 'Rajdhani', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--body);
    min-height: 100vh;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* Scanline effect */
  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* Grid background */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image:
      linear-gradient(rgba(153,69,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(153,69,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── HEADER ─── */
  header {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 56px;
    border-bottom: 1px solid var(--border);
    background: rgba(4,6,8,0.95);
    backdrop-filter: blur(10px);
  }

  .logo {
    font-family: var(--display);
    font-size: 18px;
    font-weight: 900;
    letter-spacing: 4px;
    color: var(--sol);
    text-shadow: 0 0 20px var(--sol), 0 0 40px rgba(153,69,255,0.4);
    animation: pulse-logo 3s ease-in-out infinite;
  }

  @keyframes pulse-logo {
    0%, 100% { text-shadow: 0 0 20px var(--sol), 0 0 40px rgba(153,69,255,0.4); }
    50% { text-shadow: 0 0 30px var(--sol), 0 0 60px rgba(153,69,255,0.6), 0 0 80px rgba(153,69,255,0.2); }
  }

  .logo span { color: var(--text-dim); font-weight: 300; }

  .header-center {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .pair-badge {
    font-family: var(--mono);
    font-size: 13px;
    padding: 4px 12px;
    border: 1px solid var(--sol-dim);
    background: var(--sol-glow);
    color: var(--sol);
    letter-spacing: 2px;
  }

  .live-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 2px;
  }

  .live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 10px var(--green);
    animation: blink 1.2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-chip {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 10px;
    letter-spacing: 1px;
    border: 1px solid;
  }

  .status-chip.active {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-glow);
    animation: chip-glow 2s ease-in-out infinite;
  }

  .status-chip.waiting {
    border-color: var(--yellow);
    color: var(--yellow);
    background: rgba(255,214,0,0.08);
  }

  @keyframes chip-glow {
    0%, 100% { box-shadow: 0 0 8px rgba(0,255,136,0.2); }
    50% { box-shadow: 0 0 16px rgba(0,255,136,0.4); }
  }

  /* ─── MAIN LAYOUT ─── */
  .app {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 280px 1fr 300px;
    grid-template-rows: auto 1fr auto;
    height: calc(100vh - 56px);
    gap: 0;
  }

  /* ─── PANELS ─── */
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--sol-dim), transparent);
    opacity: 0.6;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.3);
  }

  .panel-title {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .panel-tag {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--sol);
    letter-spacing: 1px;
  }

  /* ─── LEFT PANEL — Controls ─── */
  .left-panel {
    grid-row: 1 / -1;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .left-panel::-webkit-scrollbar { width: 3px; }
  .left-panel::-webkit-scrollbar-track { background: transparent; }
  .left-panel::-webkit-scrollbar-thumb { background: var(--border-bright); }

  .control-section {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--text-dim);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* API Key inputs */
  .input-group {
    margin-bottom: 12px;
  }

  .input-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 2px;
    margin-bottom: 6px;
    display: block;
  }

  .input-field {
    width: 100%;
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--mono);
    font-size: 11px;
    padding: 8px 10px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    letter-spacing: 1px;
  }

  .input-field:focus {
    border-color: var(--sol-dim);
    box-shadow: 0 0 12px var(--sol-glow);
  }

  .input-field::placeholder {
    color: var(--text-dim);
    opacity: 0.5;
  }

  /* Toggle switch */
  .toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .toggle-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text);
    letter-spacing: 1px;
  }

  .toggle {
    position: relative;
    width: 36px;
    height: 18px;
  }

  .toggle input { opacity: 0; width: 0; height: 0; }

  .toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--bg3);
    border: 1px solid var(--border);
    transition: 0.3s;
  }

  .toggle-slider::before {
    content: '';
    position: absolute;
    width: 12px; height: 12px;
    left: 2px; top: 2px;
    background: var(--text-dim);
    transition: 0.3s;
  }

  .toggle input:checked + .toggle-slider {
    background: var(--sol-glow);
    border-color: var(--sol-dim);
  }

  .toggle input:checked + .toggle-slider::before {
    transform: translateX(18px);
    background: var(--sol);
    box-shadow: 0 0 8px var(--sol);
  }

  /* Stat rows */
  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid rgba(26,37,53,0.5);
  }

  .stat-row:last-child { border-bottom: none; }

  .stat-key {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .stat-val {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-bright);
  }

  .stat-val.green { color: var(--green); }
  .stat-val.red { color: var(--red); }
  .stat-val.sol { color: var(--sol); }
  .stat-val.yellow { color: var(--yellow); }

  /* Indicator bars */
  .indicator-item {
    margin-bottom: 14px;
  }

  .ind-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
  }

  .ind-name {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 2px;
  }

  .ind-value {
    font-family: var(--mono);
    font-size: 10px;
  }

  .ind-bar-track {
    height: 3px;
    background: var(--bg3);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .ind-bar-fill {
    height: 100%;
    transition: width 1s ease, background 0.5s;
  }

  /* ─── CENTER — Chart area ─── */
  .center-panel {
    grid-row: 1 / 3;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }

  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 20px;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.4);
    flex-shrink: 0;
  }

  .price-display {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .price-main {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: 2px;
    animation: price-tick 2s ease-in-out infinite;
  }

  @keyframes price-tick {
    0%, 98%, 100% { opacity: 1; }
    99% { opacity: 0.7; }
  }

  .price-change {
    font-family: var(--mono);
    font-size: 13px;
  }

  .price-change.up { color: var(--green); }
  .price-change.down { color: var(--red); }

  .timeframe-tabs {
    display: flex;
    gap: 2px;
  }

  .tf-tab {
    font-family: var(--mono);
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s;
  }

  .tf-tab.active, .tf-tab:hover {
    border-color: var(--sol-dim);
    color: var(--sol);
    background: var(--sol-glow);
  }

  /* Fake chart canvas */
  .chart-canvas {
    flex: 1;
    position: relative;
    background: var(--bg2);
    overflow: hidden;
  }

  .chart-svg {
    width: 100%;
    height: 100%;
  }

  /* Trade signal overlay */
  .signal-overlay {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 12px 20px;
    border: 1px solid;
    font-family: var(--display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 4px;
    backdrop-filter: blur(8px);
  }

  .signal-overlay.long {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-glow);
    box-shadow: 0 0 30px rgba(0,255,136,0.15), inset 0 0 30px rgba(0,255,136,0.05);
    animation: signal-pulse-green 2s ease-in-out infinite;
  }

  .signal-overlay.short {
    border-color: var(--red);
    color: var(--red);
    background: var(--red-glow);
    box-shadow: 0 0 30px rgba(255,51,88,0.15), inset 0 0 30px rgba(255,51,88,0.05);
    animation: signal-pulse-red 2s ease-in-out infinite;
  }

  .signal-overlay.hold {
    border-color: var(--yellow);
    color: var(--yellow);
    background: rgba(255,214,0,0.05);
  }

  @keyframes signal-pulse-green {
    0%, 100% { box-shadow: 0 0 20px rgba(0,255,136,0.15); }
    50% { box-shadow: 0 0 40px rgba(0,255,136,0.3); }
  }
  @keyframes signal-pulse-red {
    0%, 100% { box-shadow: 0 0 20px rgba(255,51,88,0.15); }
    50% { box-shadow: 0 0 40px rgba(255,51,88,0.3); }
  }

  /* ─── BOTTOM CENTER — Controls bar ─── */
  .bot-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,0.5);
    flex-shrink: 0;
  }

  .btn {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 2px;
    padding: 10px 24px;
    border: 1px solid;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .btn-start {
    border-color: var(--green);
    color: var(--green);
  }

  .btn-start:hover, .btn-start.running {
    background: var(--green-glow);
    box-shadow: 0 0 20px rgba(0,255,136,0.2);
    color: var(--green);
  }

  .btn-stop {
    border-color: var(--red);
    color: var(--red);
  }

  .btn-stop:hover {
    background: var(--red-glow);
    box-shadow: 0 0 20px rgba(255,51,88,0.2);
  }

  .btn-paper {
    border-color: var(--yellow);
    color: var(--yellow);
  }

  .btn-paper:hover, .btn-paper.active {
    background: rgba(255,214,0,0.08);
    box-shadow: 0 0 20px rgba(255,214,0,0.15);
  }

  .controls-divider {
    width: 1px;
    height: 28px;
    background: var(--border);
  }

  .next-scan {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    margin-left: auto;
  }

  .next-scan span {
    color: var(--cyan);
  }

  /* ─── RIGHT PANEL — News feed ─── */
  .right-panel {
    grid-row: 1 / -1;
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .news-feed {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }

  .news-feed::-webkit-scrollbar { width: 3px; }
  .news-feed::-webkit-scrollbar-thumb { background: var(--border-bright); }

  .news-item {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s;
    animation: slide-in 0.4s ease;
  }

  @keyframes slide-in {
    from { opacity: 0; transform: translateX(10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .news-item:hover { background: rgba(153,69,255,0.05); }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .news-time {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dim);
  }

  .sentiment-badge {
    font-family: var(--mono);
    font-size: 8px;
    padding: 1px 6px;
    letter-spacing: 1px;
  }

  .sentiment-badge.bull {
    background: var(--green-glow);
    color: var(--green);
    border: 1px solid var(--green-dim);
  }

  .sentiment-badge.bear {
    background: var(--red-glow);
    color: var(--red);
    border: 1px solid var(--red-dim);
  }

  .sentiment-badge.neutral {
    background: rgba(255,214,0,0.08);
    color: var(--yellow);
    border: 1px solid rgba(255,214,0,0.3);
  }

  .news-text {
    font-size: 12px;
    color: var(--text);
    line-height: 1.5;
    font-weight: 400;
  }

  .news-impact {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 6px;
  }

  .impact-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
  }

  .impact-label {
    font-family: var(--mono);
    font-size: 8px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  /* ─── BOTTOM ROW — Trade log ─── */
  .bottom-panel {
    grid-column: 2;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    height: 160px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .log-feed {
    flex: 1;
    overflow-y: auto;
    padding: 8px 16px;
    font-family: var(--mono);
    font-size: 10px;
    line-height: 1.8;
  }

  .log-feed::-webkit-scrollbar { width: 3px; }
  .log-feed::-webkit-scrollbar-thumb { background: var(--border-bright); }

  .log-line { display: flex; gap: 12px; }
  .log-time { color: var(--text-dim); flex-shrink: 0; }
  .log-msg.info { color: var(--cyan); }
  .log-msg.success { color: var(--green); }
  .log-msg.warning { color: var(--yellow); }
  .log-msg.error { color: var(--red); }
  .log-msg.sol { color: var(--sol); }

  /* ─── CHART SVG ─── */
  .candle { transition: opacity 0.3s; }

  .bb-upper, .bb-lower { stroke-dasharray: 4 2; }

  /* responsive price labels */
  .price-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    fill: #4a6070;
  }

  /* ─── Animations ─── */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-in { animation: fade-in 0.5s ease forwards; }

  /* ─── Scrollbar global ─── */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-bright); }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo">SOLBOT <span>// v1.0</span></div>
  <div class="header-center">
    <div class="pair-badge">SOL / USD</div>
    <div class="live-indicator"><div class="live-dot"></div> LIVE FEED</div>
  </div>
  <div class="header-right">
    <span class="status-chip waiting" id="botStatusChip">STANDBY</span>
    <span class="status-chip active">KRAKEN</span>
  </div>
</header>

<!-- APP GRID -->
<div class="app">

  <!-- ─── LEFT PANEL ─── -->
  <aside class="left-panel panel">

    <!-- API Config -->
    <div class="control-section">
      <div class="section-label">API CONFIG</div>
      <div class="input-group">
        <label class="input-label">KRAKEN API KEY</label>
        <input class="input-field" type="password" placeholder="••••••••••••••••••••">
      </div>
      <div class="input-group">
        <label class="input-label">KRAKEN PRIVATE KEY</label>
        <input class="input-field" type="password" placeholder="••••••••••••••••••••">
      </div>
    </div>

    <!-- Bot Settings -->
    <div class="control-section">
      <div class="section-label">BOT SETTINGS</div>
      <div class="toggle-row">
        <span class="toggle-label">PAPER TRADE</span>
        <label class="toggle"><input type="checkbox" id="paperToggle" checked><span class="toggle-slider"></span></label>
      </div>
      <div class="toggle-row">
        <span class="toggle-label">NEWS FILTER</span>
        <label class="toggle"><input type="checkbox" checked><span class="toggle-slider"></span></label>
      </div>
      <div class="toggle-row">
        <span class="toggle-label">STOP LOSS</span>
        <label class="toggle"><input type="checkbox" checked><span class="toggle-slider"></span></label>
      </div>
      <div class="toggle-row">
        <span class="toggle-label">TAKE PROFIT</span>
        <label class="toggle"><input type="checkbox" checked><span class="toggle-slider"></span></label>
      </div>
      <div class="input-group" style="margin-top:10px">
        <label class="input-label">STOP LOSS %</label>
        <input class="input-field" type="number" value="3" min="1" max="20">
      </div>
      <div class="input-group">
        <label class="input-label">TAKE PROFIT %</label>
        <input class="input-field" type="number" value="6" min="1" max="50">
      </div>
    </div>

    <!-- Account Stats -->
    <div class="control-section">
      <div class="section-label">ACCOUNT</div>
      <div class="stat-row">
        <span class="stat-key">BALANCE</span>
        <span class="stat-val green" id="balance">$500.00</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">POSITION</span>
        <span class="stat-val sol" id="position">NONE</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">ENTRY PRICE</span>
        <span class="stat-val" id="entryPrice">—</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">P&L</span>
        <span class="stat-val" id="pnl">—</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">TOTAL TRADES</span>
        <span class="stat-val" id="totalTrades">0</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">WIN RATE</span>
        <span class="stat-val yellow" id="winRate">—</span>
      </div>
    </div>

    <!-- Indicators -->
    <div class="control-section">
      <div class="section-label">INDICATORS</div>

      <div class="indicator-item">
        <div class="ind-header">
          <span class="ind-name">RSI (14)</span>
          <span class="ind-value" id="rsiVal" style="color:var(--yellow)">58.4</span>
        </div>
        <div class="ind-bar-track">
          <div class="ind-bar-fill" id="rsiBar" style="width:58.4%;background:var(--yellow)"></div>
        </div>
      </div>

      <div class="indicator-item">
        <div class="ind-header">
          <span class="ind-name">MACD SIGNAL</span>
          <span class="ind-value" id="macdVal" style="color:var(--green)">BULL</span>
        </div>
        <div class="ind-bar-track">
          <div class="ind-bar-fill" id="macdBar" style="width:70%;background:var(--green)"></div>
        </div>
      </div>

      <div class="indicator-item">
        <div class="ind-header">
          <span class="ind-name">BB POSITION</span>
          <span class="ind-value" id="bbVal" style="color:var(--cyan)">MID</span>
        </div>
        <div class="ind-bar-track">
          <div class="ind-bar-fill" id="bbBar" style="width:50%;background:var(--cyan)"></div>
        </div>
      </div>

      <div class="indicator-item">
        <div class="ind-header">
          <span class="ind-name">MA TREND</span>
          <span class="ind-value" id="maVal" style="color:var(--green)">ABOVE</span>
        </div>
        <div class="ind-bar-track">
          <div class="ind-bar-fill" id="maBar" style="width:65%;background:var(--green)"></div>
        </div>
      </div>
    </div>

    <!-- Sentiment -->
    <div class="control-section">
      <div class="section-label">NEWS SENTIMENT</div>
      <div class="stat-row">
        <span class="stat-key">SOURCE</span>
        <span class="stat-val sol">@solidintel_x</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">SCORE</span>
        <span class="stat-val green" id="sentimentScore">+0.62</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">SIGNAL</span>
        <span class="stat-val green" id="sentimentSignal">BULLISH</span>
      </div>
      <div class="stat-row">
        <span class="stat-key">LAST UPDATE</span>
        <span class="stat-val" id="lastUpdate">2m ago</span>
      </div>
    </div>

  </aside>

  <!-- ─── CENTER PANEL ─── -->
  <main class="center-panel panel">
    <div class="chart-header">
      <div class="price-display">
        <div class="price-main" id="priceMain">$148.32</div>
        <div class="price-change up" id="priceChange">▲ +2.41%</div>
      </div>
      <div class="timeframe-tabs">
        <button class="tf-tab">5M</button>
        <button class="tf-tab">15M</button>
        <button class="tf-tab active">1H</button>
        <button class="tf-tab">4H</button>
        <button class="tf-tab">1D</button>
      </div>
    </div>

    <div class="chart-canvas">
      <svg class="chart-svg" id="chartSvg" viewBox="0 0 900 420" preserveAspectRatio="none">
        <!-- Grid lines -->
        <g id="gridLines"></g>
        <!-- Bollinger Bands -->
        <path id="bbUpper" class="bb-upper" stroke="#00d4ff" stroke-width="1" fill="none" opacity="0.5"/>
        <path id="bbLower" class="bb-lower" stroke="#00d4ff" stroke-width="1" fill="none" opacity="0.5"/>
        <path id="bbFill" fill="rgba(0,212,255,0.04)"/>
        <!-- MA lines -->
        <path id="ma20" stroke="#ffd600" stroke-width="1.5" fill="none" opacity="0.7"/>
        <path id="ma50" stroke="#ff7c1a" stroke-width="1.5" fill="none" opacity="0.7"/>
        <!-- Candles -->
        <g id="candleGroup"></g>
        <!-- Signal markers -->
        <g id="signalMarkers"></g>
        <!-- Price labels -->
        <g id="priceLabels"></g>
      </svg>
      <div class="signal-overlay long" id="signalOverlay">▲ LONG</div>
    </div>

    <div class="bot-controls">
      <button class="btn btn-start" id="startBtn" onclick="toggleBot()">▶ START BOT</button>
      <button class="btn btn-stop" onclick="stopBot()">■ STOP</button>
      <div class="controls-divider"></div>
      <button class="btn btn-paper" id="paperBtn">◈ PAPER MODE</button>
      <div class="next-scan" id="nextScan">NEXT SCAN IN <span id="countdown">59:42</span></div>
    </div>
  </main>

  <!-- ─── RIGHT PANEL — News ─── -->
  <aside class="right-panel panel">
    <div class="panel-header">
      <span class="panel-title">INTEL FEED</span>
      <span class="panel-tag">@solidintel_x</span>
    </div>
    <div class="news-feed" id="newsFeed"></div>
  </aside>

  <!-- ─── BOTTOM — Trade Log ─── -->
  <div class="bottom-panel panel">
    <div class="panel-header">
      <span class="panel-title">SYSTEM LOG</span>
      <span class="panel-tag" id="logCount">0 EVENTS</span>
    </div>
    <div class="log-feed" id="logFeed"></div>
  </div>

</div>

<script>
// ─── CHART GENERATION ───────────────────────────────────────────
const W = 900, H = 420;
let candles = [];
let botRunning = false;
let logCount = 0;
let countdown = 3600;
let countdownTimer;
let priceBase = 148.32;

function generateCandles(n = 60) {
  let price = 130 + Math.random() * 30;
  const data = [];
  for (let i = 0; i < n; i++) {
    const open = price;
    const change = (Math.random() - 0.48) * 4;
    const close = open + change;
    const high = Math.max(open, close) + Math.random() * 2;
    const low = Math.min(open, close) - Math.random() * 2;
    data.push({ open, high, low, close, bull: close >= open });
    price = close;
  }
  return data;
}

function drawChart() {
  candles = generateCandles(60);
  const prices = candles.flatMap(c => [c.high, c.low]);
  const minP = Math.min(...prices) - 2;
  const maxP = Math.max(...prices) + 2;
  const range = maxP - minP;

  const pad = { left: 10, right: 50, top: 20, bottom: 20 };
  const chartW = W - pad.left - pad.right;
  const chartH = H - pad.top - pad.bottom;

  const toX = i => pad.left + (i / (candles.length - 1)) * chartW;
  const toY = p => pad.top + (1 - (p - minP) / range) * chartH;

  // Grid
  const grid = document.getElementById('gridLines');
  grid.innerHTML = '';
  for (let i = 0; i <= 5; i++) {
    const y = pad.top + (i / 5) * chartH;
    const p = maxP - (i / 5) * range;
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', pad.left); line.setAttribute('x2', W - pad.right);
    line.setAttribute('y1', y); line.setAttribute('y2', y);
    line.setAttribute('stroke', '#1a2535'); line.setAttribute('stroke-width', '1');
    grid.appendChild(line);
    const txt = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    txt.setAttribute('x', W - pad.right + 5); txt.setAttribute('y', y + 3);
    txt.setAttribute('class', 'price-label'); txt.textContent = '$' + p.toFixed(0);
    grid.appendChild(txt);
  }

  // Candles
  const cg = document.getElementById('candleGroup');
  cg.innerHTML = '';
  const cw = chartW / candles.length * 0.6;
  candles.forEach((c, i) => {
    const x = toX(i);
    const color = c.bull ? '#00ff88' : '#ff3358';
    const wick = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    wick.setAttribute('x1', x); wick.setAttribute('x2', x);
    wick.setAttribute('y1', toY(c.high)); wick.setAttribute('y2', toY(c.low));
    wick.setAttribute('stroke', color); wick.setAttribute('stroke-width', '1');
    cg.appendChild(wick);
    const body = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    const bodyTop = Math.min(toY(c.open), toY(c.close));
    const bodyH = Math.max(1, Math.abs(toY(c.open) - toY(c.close)));
    body.setAttribute('x', x - cw / 2); body.setAttribute('y', bodyTop);
    body.setAttribute('width', cw); body.setAttribute('height', bodyH);
    body.setAttribute('fill', color); body.setAttribute('opacity', '0.85');
    cg.appendChild(body);
  });

  // MA20
  const ma20pts = candles.map((_, i) => {
    if (i < 19) return null;
    const avg = candles.slice(i - 19, i + 1).reduce((s, c) => s + c.close, 0) / 20;
    return `${toX(i)},${toY(avg)}`;
  }).filter(Boolean);
  document.getElementById('ma20').setAttribute('d', 'M' + ma20pts.join('L'));

  // MA50
  const ma50pts = candles.map((_, i) => {
    if (i < 49) return null;
    const avg = candles.slice(i - 49, i + 1).reduce((s, c) => s + c.close, 0) / 50;
    return `${toX(i)},${toY(avg)}`;
  }).filter(Boolean);
  if (ma50pts.length) document.getElementById('ma50').setAttribute('d', 'M' + ma50pts.join('L'));

  // BB
  const bbPts = candles.map((_, i) => {
    if (i < 19) return null;
    const slice = candles.slice(i - 19, i + 1).map(c => c.close);
    const avg = slice.reduce((a, b) => a + b, 0) / 20;
    const std = Math.sqrt(slice.reduce((s, v) => s + (v - avg) ** 2, 0) / 20);
    return { x: toX(i), upper: toY(avg + 2 * std), lower: toY(avg - 2 * std) };
  }).filter(Boolean);

  if (bbPts.length) {
    const upper = 'M' + bbPts.map(p => `${p.x},${p.upper}`).join('L');
    const lower = 'M' + bbPts.map(p => `${p.x},${p.lower}`).join('L');
    const fill = upper + 'L' + bbPts.slice().reverse().map(p => `${p.x},${p.lower}`).join('L') + 'Z';
    document.getElementById('bbUpper').setAttribute('d', upper);
    document.getElementById('bbLower').setAttribute('d', lower);
    document.getElementById('bbFill').setAttribute('d', fill);
  }

  // Signal markers — last 5 random signals
  const sm = document.getElementById('signalMarkers');
  sm.innerHTML = '';
  [10, 22, 35, 45, 55].forEach((ci, idx) => {
    const signals = ['L', 'S', 'L', 'L', 'S'];
    const sig = signals[idx];
    const c = candles[ci];
    const x = toX(ci);
    const y = sig === 'L' ? toY(c.low) + 12 : toY(c.high) - 12;
    const color = sig === 'L' ? '#00ff88' : '#ff3358';
    const tri = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    tri.setAttribute('x', x); tri.setAttribute('y', y);
    tri.setAttribute('text-anchor', 'middle');
    tri.setAttribute('fill', color);
    tri.setAttribute('font-size', '12');
    tri.textContent = sig === 'L' ? '▲' : '▼';
    sm.appendChild(tri);
  });
}

// ─── NEWS FEED ───────────────────────────────────────────────────
const mockTweets = [
  { text: "🚨 SOL whale just moved 2.4M tokens to exchange — watch for pressure", sentiment: "bear", impact: "high", time: "1m ago" },
  { text: "Solana network processing 65k TPS — chain health looks strong heading into weekend", sentiment: "bull", time: "4m ago", impact: "medium" },
  { text: "SOL holding key support at $145. Bulls need to defend this level.", sentiment: "neutral", time: "9m ago", impact: "low" },
  { text: "🔥 DeFi TVL on Solana hits new ATH — ecosystem momentum building", sentiment: "bull", time: "14m ago", impact: "high" },
  { text: "Liquidation cascade risk if SOL breaks below $142", sentiment: "bear", time: "22m ago", impact: "medium" },
  { text: "BREAKING: Major protocol launching on Solana next week — team confirms", sentiment: "bull", time: "31m ago", impact: "high" },
  { text: "SOL/BTC pair showing relative weakness. Rotate caution advised.", sentiment: "bear", time: "45m ago", impact: "low" },
  { text: "Options market showing heavy call buying at $155 strike — bullish positioning", sentiment: "bull", time: "58m ago", impact: "medium" },
];

function renderNews() {
  const feed = document.getElementById('newsFeed');
  feed.innerHTML = '';
  mockTweets.forEach(tweet => {
    const item = document.createElement('div');
    item.className = 'news-item';
    const impactColor = { high: '#ff3358', medium: '#ffd600', low: '#4a6070' }[tweet.impact];
    item.innerHTML = `
      <div class="news-meta">
        <span class="news-time">${tweet.time}</span>
        <span class="sentiment-badge ${tweet.sentiment}">${tweet.sentiment.toUpperCase()}</span>
      </div>
      <div class="news-text">${tweet.text}</div>
      <div class="news-impact">
        <div class="impact-dot" style="background:${impactColor}"></div>
        <span class="impact-label">IMPACT: ${tweet.impact.toUpperCase()}</span>
      </div>
    `;
    feed.appendChild(item);
  });
}

// ─── LOG SYSTEM ──────────────────────────────────────────────────
function addLog(msg, type = 'info') {
  const feed = document.getElementById('logFeed');
  const now = new Date();
  const time = now.toTimeString().slice(0,8);
  const line = document.createElement('div');
  line.className = 'log-line';
  line.innerHTML = `<span class="log-time">[${time}]</span><span class="log-msg ${type}">${msg}</span>`;
  feed.appendChild(line);
  feed.scrollTop = feed.scrollHeight;
  logCount++;
  document.getElementById('logCount').textContent = `${logCount} EVENTS`;
}

// ─── COUNTDOWN ───────────────────────────────────────────────────
function startCountdown() {
  countdown = 3600;
  if (countdownTimer) clearInterval(countdownTimer);
  countdownTimer = setInterval(() => {
    countdown--;
    if (countdown <= 0) {
      countdown = 3600;
      runScanCycle();
    }
    const m = String(Math.floor(countdown / 60)).padStart(2, '0');
    const s = String(countdown % 60).padStart(2, '0');
    document.getElementById('countdown').textContent = `${m}:${s}`;
  }, 1000);
}

// ─── PRICE SIMULATION ────────────────────────────────────────────
function simulatePrice() {
  setInterval(() => {
    if (!botRunning) return;
    const change = (Math.random() - 0.49) * 0.8;
    priceBase += change;
    const pct = ((priceBase - 148.32) / 148.32 * 100).toFixed(2);
    document.getElementById('priceMain').textContent = `$${priceBase.toFixed(2)}`;
    const changeEl = document.getElementById('priceChange');
    if (change >= 0) {
      changeEl.textContent = `▲ +${pct}%`;
      changeEl.className = 'price-change up';
    } else {
      changeEl.textContent = `▼ ${pct}%`;
      changeEl.className = 'price-change down';
    }
    updateIndicators();
  }, 3000);
}

// ─── INDICATOR UPDATES ───────────────────────────────────────────
function updateIndicators() {
  const rsi = 40 + Math.random() * 40;
  const rsiEl = document.getElementById('rsiVal');
  const rsiBar = document.getElementById('rsiBar');
  rsiEl.textContent = rsi.toFixed(1);
  rsiBar.style.width = rsi + '%';
  if (rsi > 70) { rsiEl.style.color = 'var(--red)'; rsiBar.style.background = 'var(--red)'; }
  else if (rsi < 30) { rsiEl.style.color = 'var(--green)'; rsiBar.style.background = 'var(--green)'; }
  else { rsiEl.style.color = 'var(--yellow)'; rsiBar.style.background = 'var(--yellow)'; }
}

// ─── SCAN CYCLE ──────────────────────────────────────────────────
function runScanCycle() {
  addLog('Hourly scan initiated — fetching SOL/USD 1H candles from Kraken...', 'info');
  setTimeout(() => addLog('60 candles loaded. Running TA calculations...', 'info'), 800);
  setTimeout(() => {
    addLog('RSI: 58.4 | MACD: Bullish crossover | BB: Price near midline | MA: Above 20/50', 'sol');
    addLog('Scraping @solidintel_x for recent posts...', 'info');
  }, 1600);
  setTimeout(() => {
    addLog('Sentiment score: +0.62 (BULLISH) — 3 bull signals, 1 bear signal detected', 'success');
    addLog('Signal fusion: TA=BULL + Sentiment=BULL → LONG signal generated', 'success');
    addLog('Executing LONG order: $500 SOL/USD on Kraken...', 'warning');
  }, 2400);
  setTimeout(() => {
    addLog('✓ Order filled at $148.32 | Stop Loss: $143.87 | Take Profit: $157.22', 'success');
    document.getElementById('position').textContent = 'LONG';
    document.getElementById('position').style.color = 'var(--green)';
    document.getElementById('entryPrice').textContent = '$148.32';
    drawChart();
  }, 3200);
}

// ─── BOT CONTROLS ────────────────────────────────────────────────
function toggleBot() {
  botRunning = !botRunning;
  const btn = document.getElementById('startBtn');
  const chip = document.getElementById('botStatusChip');
  if (botRunning) {
    btn.textContent = '⏸ PAUSE BOT';
    btn.classList.add('running');
    chip.textContent = 'RUNNING';
    chip.className = 'status-chip active';
    addLog('Bot initialized. Connecting to Kraken WebSocket...', 'info');
    setTimeout(() => addLog('✓ Kraken feed connected. Monitoring SOL/USD 1H', 'success'), 600);
    setTimeout(() => addLog('✓ @solidintel_x scraper active. Polling every 5 minutes.', 'success'), 1200);
    setTimeout(() => runScanCycle(), 2000);
    startCountdown();
    simulatePrice();
  } else {
    btn.textContent = '▶ START BOT';
    btn.classList.remove('running');
    chip.textContent = 'PAUSED';
    chip.className = 'status-chip waiting';
    addLog('Bot paused. Open positions maintained.', 'warning');
    if (countdownTimer) clearInterval(countdownTimer);
  }
}

function stopBot() {
  botRunning = false;
  const btn = document.getElementById('startBtn');
  const chip = document.getElementById('botStatusChip');
  btn.textContent = '▶ START BOT';
  btn.classList.remove('running');
  chip.textContent = 'STANDBY';
  chip.className = 'status-chip waiting';
  if (countdownTimer) clearInterval(countdownTimer);
  addLog('Bot stopped. All orders cancelled. Positions closed.', 'error');
  document.getElementById('position').textContent = 'NONE';
  document.getElementById('position').style.color = 'var(--sol)';
  document.getElementById('entryPrice').textContent = '—';
}

// Timeframe tabs
document.querySelectorAll('.tf-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.tf-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    drawChart();
    addLog(`Timeframe switched to ${this.textContent}`, 'info');
  });
});

// ─── INIT ────────────────────────────────────────────────────────
drawChart();
renderNews();
addLog('SOLBOT v1.0 initialized. Configure API keys and press START.', 'sol');
addLog('Paper trading mode active — no real orders will be placed.', 'warning');

// Refresh news periodically
setInterval(() => {
  const newTweet = mockTweets.shift();
  mockTweets.push({ ...newTweet, time: '0m ago' });
  renderNews();
}, 30000);
</script>
