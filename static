    </div>

    <div class="pattern-visual">${getPatternSVG(p)}</div>

    <div class="detail-grid">
      <div class="detail-card">
        <div class="detail-card-label">BASE RELIABILITY</div>
        <div class="detail-card-value" style="color:${confColor}">${p.reliability}%</div>
      </div>
      <div class="detail-card">
        <div class="detail-card-label">HISTORICAL WIN RATE</div>
