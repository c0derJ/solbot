let activeCategory = 'All';
let activePattern = null;
let aiReviewCount = 0;

const categories = ['All', ...new Set(PATTERNS.map(p => p.category))];

function initCategoryTabs() {
  const container = document.getElementById('categoryTabs');
  categories.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'cat-tab' + (cat === 'All' ? ' active' : '');
    btn.textContent = cat.toUpperCase();
    btn.onclick = () => {
      document.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = cat;
      renderPatternList();
    };
    container.appendChild(btn);
  });
}

function filterPatterns() {
  renderPatternList();
}

function renderPatternList() {
  const list = document.getElementById('patternList');
  const query = document.getElementById('searchInput').value.toLowerCase();
  list.innerHTML = '';

  const filtered = PATTERNS.filter(p => {
    const matchCat = activeCategory === 'All' || p.category === activeCategory;
    const matchSearch = !query || p.name.toLowerCase().includes(query) || p.subcategory.toLowerCase().includes(query);
    return matchCat && matchSearch;
  });

  document.getElementById('patternCount').textContent = `${filtered.length} PATTERNS`;

  filtered.forEach(p => {
    const item = document.createElement('div');
    item.className = 'pattern-item' + (activePattern?.id === p.id ? ' active' : '');
    item.onclick = () => showPattern(p);

    const signalColor = p.signal === 'BULLISH' ? 'var(--green)' : p.signal === 'BEARISH' ? 'var(--red)' : 'var(--yellow)';
    const confColor = p.reliability >= 80 ? 'var(--green)' : p.reliability >= 70 ? 'var(--yellow)' : 'var(--red)';

    item.innerHTML = `
      <div class="pattern-left">
        <div class="pattern-name">${p.name}</div>
        <div class="pattern-type">${p.category} · ${p.subcategory}</div>
      </div>
      <div class="pattern-right">
        <div style="display:flex;align-items:center;gap:5px">
          <div class="signal-dot" style="background:${signalColor};box-shadow:0 0 5px ${signalColor}"></div>
          <div class="confidence-bar-mini"><div class="confidence-fill-mini" style="width:${p.reliability}%;background:${confColor}"></div></div>
          <div class="confidence-pct" style="color:${confColor}">${p.reliability}%</div>
        </div>
      </div>
    `;
    list.appendChild(item);
  });
}

